# =========================================================
# OPERATION: TURING ADJUSTER — environment template
# Copy to .env and fill in.  NEVER commit the real .env.
# =========================================================

# --- LLM (the conversational brain) -----------------------
# Pluggable provider — set to "gemini" (default) or "ollama" or "openai".
# If the configured provider isn't reachable, agent.brain.make_brain()
# auto-falls-through to the next available one.  Use "ollama" if Google
# free tier melts down (run `ollama pull llama3.2` first).
BRAIN_PROVIDER=gemini

# --- Local Ollama (only if BRAIN_PROVIDER=ollama) ---------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# --- OpenAI (only if BRAIN_PROVIDER=openai) ---------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Use the rolling alias "gemini-flash-latest" — it always routes to the
# current best public Flash model.  gemini-2.5-flash works too when its
# free-tier quota isn't exhausted, but the alias side-steps both
# rate-limit hot-spotting AND silent deprecations like gemini-2.0-flash
# ("no longer available to new users").  Run scripts/diagnose_gemini.py
# to see what your key can actually reach.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Anthropic — used only by the juror bot for adversarial testing.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Voice (Gradium) --------------------------------------
GRADIUM_API_KEY=
# voice_id from studio.gradium.ai — flagship "Emma" works fine to start
GRADIUM_VOICE_ID=
GRADIUM_REGION=eu       # eu or us

# --- Telephony (LiveKit / Twilio) -------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Twilio supports TWO auth modes — use whichever you have.
#
#   Mode A (master credentials, full account access):
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
#
#   Mode B (scoped API-Key — what Inca usually hands out, more secure):
#   set ACCOUNT_SID + API_KEY_SID + API_KEY_SECRET (and leave AUTH_TOKEN empty).
#   In Python:  Client(api_key_sid, api_key_secret, account_sid)
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

TWILIO_PHONE_NUMBER=

# --- Tavily (real-time web context for Jamie) -------------
TAVILY_API_KEY=

# --- Pioneer / Fastino (extraction fine-tune + eval) -----
FASTINO_API_KEY=
FASTINO_PIONEER_PROJECT=

# --- Bridge / dashboard ----------------------------------
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Which CRM mock to inject for the demo call
DEMO_CRM_PROFILE=max_mueller
